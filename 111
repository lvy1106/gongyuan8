                                    <line x1="350" y1="117" x2="373" y2="102" stroke="#ffffff" stroke-width="3.5" stroke-linecap="round"/>
                                    <line x1="350" y1="142" x2="373" y2="127" stroke="#ffffff" stroke-width="3.5" stroke-linecap="round"/>
