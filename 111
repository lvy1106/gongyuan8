                                      fill="#ffffff" 
                                      text-anchor="middle"
                                      font-weight="bold">公</text>
                                <text x="270" y="165" 
                                      font-family="'Ma Shan Zheng', 'STKaiti', 'KaiTi', '楷体', cursive" 
